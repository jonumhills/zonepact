# ── AI ───────────────────────────────────────────────────────────────────────
# Direct Anthropic (local dev fallback — used when AWS_ACCESS_KEY_ID is unset)
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS (activates Bedrock + S3 + SNS when both are set) ─────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=zonepact-reports
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:zonepact-parcel-alerts

# ── Base Sepolia x402 gate ────────────────────────────────────────────────────
ZONEPACT_EVM_ADDRESS=0xYourOperatorWalletAddress
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
MIN_PAYMENT_WEI=1000000000000000

# ── ZonePactRegistry (Base Sepolia) ──────────────────────────────────────────
REGISTRY_ADDRESS=0x82b5Bb6A1F76484C28b87d59c984656DA9aD04Bc

# ── Supabase (Wake County parcel + petition data) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_...

# ── Dev only ──────────────────────────────────────────────────────────────────
DISABLE_PAYMENT_GATE=false
