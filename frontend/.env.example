# ── Mapbox ────────────────────────────────────────────────────────────────────
# Public token (pk.*) — get from mapbox.com/account/access-tokens
VITE_MAPBOX_TOKEN=pk.your_public_token_here

# ── Parcel tilesets ───────────────────────────────────────────────────────────
VITE_TILESET_ID=username.tileset_id
VITE_PARCEL_SOURCE_LAYER=arlington_parcels
VITE_PARCEL_RPC_FIELD=RPC

# ── x402 payment gate ─────────────────────────────────────────────────────────
# Operator wallet address — ETH payments for queries go here
VITE_ZONEPACT_EVM_ADDRESS=0xYourOperatorWalletAddress
# Set to true to skip payment gate in local dev
VITE_DISABLE_PAYMENT_GATE=false

# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
